# Normalize line endings to LF in the repo; let git handle checkout conversion
* text=auto eol=lf

# Force LF for these even on Windows checkouts
*.java text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
nginx.conf text eol=lf

# Treat binaries as binary (no line ending conversion)
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.ico binary
