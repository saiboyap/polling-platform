# ── Spring Boot / Maven ──────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# Maven wrapper (keep the jar, ignore the properties if generated locally)
.mvn/wrapper/maven-wrapper.properties

# Spring Boot dev tools restart trigger
.reloadtrigger

# Application secrets / environment overrides (never commit these)
backend/src/main/resources/application-local.yml
backend/src/main/resources/application-local.properties
backend/src/main/resources/application-secrets.yml
*.env
.env
.env.*

# ── React / Node ──────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/coverage/

# Vite cache
frontend/.vite/

# TypeScript build info
frontend/tsconfig.tsbuildinfo

# ── Docker ───────────────────────────────────────────────────────────────────
# Keep docker-compose.yml but ignore any local override
docker-compose.override.yml
docker-compose.local.yml

# ── Claude Code ──────────────────────────────────────────────────────────────
.claude/

